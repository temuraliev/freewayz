# ─── Telegram Bot ──────────────────────────────────────────
# Get token from @BotFather: https://t.me/BotFather
BOT_TOKEN=

# Your Telegram user ID(s), comma-separated. Get from @userinfobot
ADMIN_TELEGRAM_IDS=

# ─── App URLs ──────────────────────────────────────────────
# Public URL of your Vercel deployment
NEXT_PUBLIC_APP_URL=https://freewayz.vercel.app

# ─── PostgreSQL (CRM: users, orders, promos, suppliers) ────
# Vercel Postgres, Neon, Supabase, or self-hosted
DATABASE_URL=postgresql://user:password@host:5432/freewayz?sslmode=require

# ─── Sanity CMS (catalog: products, brands, styles) ────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Write token (needed for admin panel edits and import scripts)
SANITY_API_TOKEN=

# ─── Admin Panel ───────────────────────────────────────────
# Password for /admin/login
ADMIN_PANEL_PASSWORD=
# Random 32+ char string for HMAC session signing
# Generate with: openssl rand -hex 32
ADMIN_PANEL_SECRET=

# ─── Rate Limiting (Upstash Redis) ─────────────────────────
# Create free DB at https://console.upstash.com/
# Optional — falls back to in-memory limiter if not set
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── 17track (package tracking) ────────────────────────────
# https://api.17track.net/
TRACK17_API_KEY=

# ─── Gemini AI (for Yupoo import --ai flag) ────────────────
# Get key at https://aistudio.google.com/apikey
# Single key or comma-separated for quota rotation
GEMINI_API_KEY=
# GEMINI_API_KEYS=key1,key2,key3

# ─── Sentry error tracking (optional) ──────────────────────
# Create a project at https://sentry.io — free tier 5k events/month
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── Optional ──────────────────────────────────────────────
# Yandex Metrica tracking ID
NEXT_PUBLIC_YANDEX_METRICA_ID=
# Show prices in USD instead of UZS
NEXT_PUBLIC_PRICES_IN_USD=false
